# ─── Secrets — NEVER commit ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials.json

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ─── ML model artifacts (binary, large) ──────────────────────────────────────
backend/ml/models/*.joblib
backend/ml/models/*.pkl
backend/ml/models/*.bin
backend/ml/models/*.pt
backend/ml/models/*.h5
# Keep metrics.json (small, useful for CI)
!backend/ml/models/metrics.json

# ─── Generated data (large CSV files) ────────────────────────────────────────
data/transactions.csv
data/accounts.csv
data/customers.csv
# Keep the .gitkeep placeholder
!data/.gitkeep

# ─── ChromaDB vector store (large binary) ─────────────────────────────────────
data/chroma/

# ─── Generated PDF reports ────────────────────────────────────────────────────
data/reports/

# ─── Temporary graph HTML exports ─────────────────────────────────────────────
/tmp/*.html

# ─── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache
.pytest_cache/
**/.pytest_cache
.coverage
htmlcov/
.tox/

# ─── Type checking ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Docker ───────────────────────────────────────────────────────────────────
docker/volumes/

# ─── Jupyter (if used for exploration) ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
