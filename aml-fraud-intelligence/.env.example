# ─── Snowflake (analytical cold path) ────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your-account.us-east-1
SNOWFLAKE_USER=aml_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=AML_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# ─── Kafka (event streaming) ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TX_RAW=transactions.raw
KAFKA_TOPIC_TX_SCORED=transactions.scored
KAFKA_TOPIC_TX_FLAGGED=transactions.flagged
KAFKA_TOPIC_RISK_ALERTS=risk.alerts
KAFKA_TOPIC_SAR_REQUESTS=sar.requests

# ─── Redis (hot path cache + feature store) ───────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Neo4j (graph engine) ─────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ─── GenAI ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_optional
LLM_PROVIDER=gemini   # gemini | openai

# ─── API Security ─────────────────────────────────────────────────────────────
API_KEY=your-secret-api-key-here
API_KEY_HEADER=X-API-Key

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development    # development | production
LOG_LEVEL=INFO
BACKEND_URL=http://backend:8000
